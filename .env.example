# OpenSearch Connection
OPENSEARCH_URL=https://localhost:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=admin

# Authentication (disable for local development)
AG_UI_AUTH_ENABLED=false

# CORS (allow OpenSearch Dashboards origin)
AG_UI_CORS_ORIGINS=http://localhost:5601

# LLM Provider — choose one:

# Option 1: AWS Bedrock
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
# need to set default region since otherwise region from default aws profile
# in aws .credentials file might be picked up instead
# AWS_DEFAULT_REGION=us-east-1
# BEDROCK_INFERENCE_PROFILE_ARN=...

# Option 2: Ollama (local)
# OLLAMA_MODEL=llama3

# Logging
AG_UI_LOG_FORMAT=human
AG_UI_LOG_LEVEL=INFO

# OS MCP Server
MCP_SERVER_URL=http://localhost:9900/mcp

# OTEL
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:6006
OTEL_SERVICE_NAME=agentic-relevance-tuning

# Prevent timeouts for longer running sub-agents
AG_UI_MAX_CONSECUTIVE_TIMEOUTS=18000

# Prevent too short waiting times for events (default = 0.1)
# with the default setting longer running requests will be terminated and
# leave incomplete responses. Values such as 10.0 are more realistic
# for longer runs. Time in seconds.
AG_UI_DEFAULT_EVENT_STREAM_CHECK_TIMEOUT=10.0

# (Optional) promptfoo testing settings
# AWS_BEARER_TOKEN_BEDROCK=... # needed for llm based evaluation via bedrock
# AG_UI_HOST=127.0.0.1 # which ag ui server to use for testing of the agent system
# AG_UI_PORT=8001 # port of ag ui server against which to test the agent system
# opensearch connection details for retrieval of index details to generate
# functional tests based on an existing index
# TEST_GEN_OPENSEARCH_URL=https://localhost:9200
# TEST_GEN_OPENSEARCH_USERNAME=admin
# TEST_GEN_OPENSEARCH_PASSWORD=...
